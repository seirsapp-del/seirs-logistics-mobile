# Environment
PORT=3000
NODE_ENV=production

# Database (PostgreSQL)
# Use DATABASE_URL for Railway/cloud providers — takes priority over individual fields
DATABASE_URL=postgresql://user:pass@host:5432/seirs_db
# Or use individual fields for local dev:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=yourpassword
# DB_NAME=seirs_db

# Auth
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')|console.log"
JWT_SECRET=generate-with-crypto-randomBytes-64

# Flutterwave (sole payment processor)
FLUTTERWAVE_SECRET_KEY=FLWSECK_LIVE-xxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_LIVE-xxxx
# Set this in Flutterwave dashboard -> Settings -> Webhooks -> Secret Hash
FLW_WEBHOOK_HASH=your-webhook-secret-hash

# Mail (Resend SMTP — resend.com, free 3,000 emails/month)
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USER=resend
MAIL_PASS=re_xxxx
MAIL_FROM=Seirs App <noreply@seirs.co>

# Firebase Cloud Messaging (push notifications)
# Go to console.firebase.google.com -> Project Settings -> Service Accounts
# -> Generate new private key -> paste the entire JSON file contents here (one line)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Cloudflare R2 (file storage — KYC docs, proof photos)
# Industry standard: S3-compatible, zero egress fees, 10GB free forever
# Sign up: dash.cloudflare.com -> R2 -> Create bucket -> Manage R2 API tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=seirs-uploads
# Enable public access on your R2 bucket to get this URL
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Public API URL (used in email links)
API_URL=https://api.seirs.co

# Deep link — seirsmobile:/ for production standalone builds
DEEP_LINK_BASE=seirsmobile:/

# Redis (optional — enables real-time GPS caching; app works without it)
REDIS_URL=redis://localhost:6379

# Google Maps (restrict to your app's bundle ID in Google Cloud Console)
GOOGLE_MAPS_API_KEY=AIzaxxxx

# SMS (not active — add Africa's Talking when ready for OTP verification)
# AFRICAS_TALKING_API_KEY=xxxx
# AFRICAS_TALKING_USERNAME=seirs
