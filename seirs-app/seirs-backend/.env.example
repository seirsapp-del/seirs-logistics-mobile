# Environment
PORT=3000
NODE_ENV=production

# Database (PostgreSQL)
DB_HOST=your-db-host
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-db-password
DB_NAME=seirs_db

# Auth
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Payments
PAYSTACK_SECRET_KEY=sk_live_xxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_LIVE-xxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_LIVE-xxxx

# Mail (Resend SMTP)
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USER=resend
MAIL_PASS=re_xxxx
MAIL_FROM=Seirs App <noreply@seirs.co>

# Public API URL (used for file links in emails)
API_URL=https://api.seirs.co

# Deep link — seirsmobile:/ for production standalone builds
DEEP_LINK_BASE=seirsmobile:/

# Redis (optional — app works without it, just no GPS caching)
REDIS_URL=redis://localhost:6379

# Google Maps
GOOGLE_MAPS_API_KEY=AIzaxxxx
