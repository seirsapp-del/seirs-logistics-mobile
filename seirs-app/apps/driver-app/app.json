{
  "expo": {
    "name": "Seirs Driver",
    "slug": "seirs-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "seirsdriver",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "co.seirs.driver",
      "config": {
        "googleMapsApiKey": "AIzaSyD4sOfs9SBTWE36xzak3aTwsbt-a0mgcSc"
      }
    },
    "android": {
      "package": "co.seirs.driver",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAvMkPsFLms7sJY8rd_44mf-ibQaYGEJPs"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      ["expo-splash-screen", {
        "image": "./assets/images/splash-icon.png",
        "imageWidth": 200,
        "resizeMode": "contain",
        "backgroundColor": "#000000",
        "dark": { "backgroundColor": "#000000" }
      }],
      ["expo-location", {
        "locationAlwaysAndWhenInUsePermission": "Seirs Driver needs your location to assign deliveries and show customers where their package is.",
        "locationWhenInUsePermission": "Seirs Driver needs your location for active deliveries.",
        "isIosBackgroundLocationEnabled": true,
        "isAndroidBackgroundLocationEnabled": true
      }],
      ["expo-image-picker", {
        "photosPermission": "Seirs Driver needs access to your photos for KYC documents.",
        "cameraPermission": "Seirs Driver needs camera access for proof of delivery photos."
      }]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e05f509d-a1ba-4e9c-a56b-42082e65df0d"
      }
    },
    "runtimeVersion": { "policy": "appVersion" },
    "updates": {
      "url": "https://u.expo.dev/e05f509d-a1ba-4e9c-a56b-42082e65df0d"
    }
  }
}
